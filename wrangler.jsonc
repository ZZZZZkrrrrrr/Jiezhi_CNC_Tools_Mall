{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "jiezhi-cnc-tools",
  "compatibility_date": "2026-07-22",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "routes": [
    {
      "pattern": "zhike.xyz/*",
      "zone_name": "zhike.xyz"
    }
  ],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  }
}
